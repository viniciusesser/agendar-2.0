generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ag_empresas {
  id               String                @id @default(uuid())
  nome             String
  telefone         String?
  plano            String                @default("free")
  plano_validade   DateTime?
  ativo            Boolean               @default(true)
  deleted_at       DateTime?
  criado_em        DateTime              @default(now())
  usuarios         ag_usuarios[]
  profissionais    ag_profissionais[]
  clientes         ag_clientes[]
  servicos         ag_servicos[]
  agendamentos     ag_agendamentos[]
  bloqueios        ag_bloqueios[]
  financeiro       ag_financeiro[]
  socias           ag_socias[]
  estoque          ag_estoque[]
  configuracoes    ag_configuracoes[]
  push_subscriptions ag_push_subscriptions[]
}

model ag_usuarios {
  id         String      @id @default(uuid())
  empresa_id String
  nome       String
  email      String      @unique
  senha_hash String
  perfil     String      @default("funcionario")
  ativo      Boolean     @default(true)
  deleted_at DateTime?
  criado_em  DateTime    @default(now())
  empresa    ag_empresas @relation(fields: [empresa_id], references: [id])
  push_subscriptions ag_push_subscriptions[]
}

model ag_profissionais {
  id                String                  @id @default(uuid())
  empresa_id        String
  usuario_id        String?
  nome              String
  cor               String                  @default("#C4748A")
  comissao_pct      Decimal                 @default(0)
  ativo             Boolean                 @default(true)
  deleted_at        DateTime?
  criado_em         DateTime                @default(now())
  empresa           ag_empresas             @relation(fields: [empresa_id], references: [id])
  agendamentos      ag_agendamentos[]
  bloqueios         ag_bloqueios[]
  socia             ag_socias?
  financeiro_div    ag_financeiro_divisao[]
  comissoes_servico ag_servico_comissao[]
  comissao_produto_pct Decimal?  @default(0)
}

model ag_socias {
  id               String           @id @default(uuid())
  empresa_id       String
  profissional_id  String           @unique
  percentual       Decimal
  ativo            Boolean          @default(true)
  criado_em        DateTime         @default(now())
  empresa          ag_empresas      @relation(fields: [empresa_id], references: [id])
  profissional     ag_profissionais @relation(fields: [profissional_id], references: [id])
}

model ag_clientes {
  id           String            @id @default(uuid())
  empresa_id   String
  nome         String
  telefone     String?
  aniversario  DateTime?
  debito       Decimal           @default(0)
  observacoes  String?
  deleted_at   DateTime?
  criado_em    DateTime          @default(now())
  empresa      ag_empresas       @relation(fields: [empresa_id], references: [id])
  agendamentos ag_agendamentos[]
  financeiro   ag_financeiro[]
}

model ag_servicos {
  id           String                @id @default(uuid())
  empresa_id   String
  nome         String
  duracao_min  Int                   @default(60)
  preco        Decimal               @default(0)
  ativo        Boolean               @default(true)
  deleted_at   DateTime?
  criado_em    DateTime              @default(now())
  empresa      ag_empresas           @relation(fields: [empresa_id], references: [id])
  agendamentos ag_agendamentos[]
  comissoes    ag_servico_comissao[]
}

model ag_agendamentos {
  id              String                  @id @default(uuid())
  empresa_id      String
  cliente_id      String
  profissional_id String
  servico_id      String
  data_hora_inicio DateTime
  duracao_min     Int
  data_hora_fim   DateTime
  valor           Decimal
  comissao_pct    Decimal                 @default(0)
  comissao_valor  Decimal                 @default(0)
  status          String                  @default("agendado")
  forma_pagamento String?
  observacoes     String?
  version         Int                     @default(1)
  deleted_at      DateTime?
  criado_em       DateTime                @default(now())
  finalizado_em   DateTime?
  empresa         ag_empresas             @relation(fields: [empresa_id], references: [id])
  cliente         ag_clientes             @relation(fields: [cliente_id], references: [id])
  profissional    ag_profissionais        @relation(fields: [profissional_id], references: [id])
  servico         ag_servicos             @relation(fields: [servico_id], references: [id])
  financeiro      ag_financeiro[]
}

model ag_bloqueios {
  id               String           @id @default(uuid())
  empresa_id       String
  profissional_id  String
  data_hora_inicio DateTime
  data_hora_fim    DateTime
  motivo           String?
  criado_em        DateTime         @default(now())
  empresa          ag_empresas      @relation(fields: [empresa_id], references: [id])
  profissional     ag_profissionais @relation(fields: [profissional_id], references: [id])
}

model ag_financeiro {
  id               String                  @id @default(uuid())
  empresa_id       String
  tipo             String
  origem           String
  valor            Decimal
  descricao        String?
  forma_pagamento  String?
  cliente_id       String?
  agendamento_id   String?
  data             DateTime                @default(now())
  criado_em        DateTime                @default(now())
  responsavel      String?                 @default("sistema")
  status           String                  @default("pago")
  empresa          ag_empresas             @relation(fields: [empresa_id], references: [id])
  cliente          ag_clientes?            @relation(fields: [cliente_id], references: [id])
  agendamento      ag_agendamentos?        @relation(fields: [agendamento_id], references: [id])
  divisoes         ag_financeiro_divisao[]
}

model ag_financeiro_divisao {
  id               String           @id @default(uuid())
  empresa_id       String
  financeiro_id    String
  profissional_id  String
  tipo             String
  percentual       Decimal
  valor            Decimal
  financeiro       ag_financeiro    @relation(fields: [financeiro_id], references: [id])
  profissional     ag_profissionais @relation(fields: [profissional_id], references: [id])
}

model ag_estoque {
  id               String                     @id @default(uuid())
  empresa_id       String
  nome             String
  quantidade       Decimal                    @default(0)
  unidade          String                     @default("un")
  rendimento_est   Decimal?
  estoque_minimo   Decimal                    @default(0)
  deleted_at       DateTime?
  criado_em        DateTime                   @default(now())
  empresa          ag_empresas                @relation(fields: [empresa_id], references: [id])
  movimentacoes    ag_estoque_movimentacoes[]
  preco_compra     Decimal?                   @default(0.00) @db.Decimal(10, 2)
  preco_venda      Decimal?                   @default(0.00) @db.Decimal(10, 2)
}

model ag_estoque_movimentacoes {
  id               String      @id @default(uuid())
  empresa_id       String
  produto_id       String
  tipo             String
  quantidade       Decimal
  motivo           String?
  agendamento_id   String?
  data             DateTime    @default(now())
  produto          ag_estoque  @relation(fields: [produto_id], references: [id])
}

model ag_convites {
  id         String   @id @default(uuid())
  empresa_id String
  token      String   @unique
  email      String?
  perfil     String   @default("funcionario")
  usado      Boolean  @default(false)
  expira_em  DateTime
  criado_em  DateTime @default(now())
}

model ag_servico_comissao {
  id               String           @id @default(uuid())
  empresa_id       String
  profissional_id  String
  servico_id       String
  comissao_pct     Decimal
  profissional     ag_profissionais @relation(fields: [profissional_id], references: [id])
  servico          ag_servicos      @relation(fields: [servico_id], references: [id])

  @@unique([profissional_id, servico_id])
}

model ag_configuracoes {
  id         String      @id @default(uuid())
  empresa_id String
  chave      String
  valor      String
  empresa    ag_empresas @relation(fields: [empresa_id], references: [id])

  @@unique([empresa_id, chave])
}

model ag_push_subscriptions {
  id          String   @id @default(uuid())
  usuario_id  String
  empresa_id  String
  endpoint    String   @unique
  p256dh      String
  auth        String
  criado_em   DateTime @default(now())
  usuario     ag_usuarios @relation(fields: [usuario_id], references: [id])
  empresa     ag_empresas @relation(fields: [empresa_id], references: [id])
}