generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ag_empresas {
  id             String             @id @default(uuid())
  nome           String
  telefone       String?
  plano          String             @default("free")
  plano_validade DateTime?
  ativo          Boolean            @default(true)
  deleted_at     DateTime?
  criado_em      DateTime           @default(now())
  usuarios       ag_usuarios[]
  profissionais  ag_profissionais[]
  clientes       ag_clientes[]
  servicos       ag_servicos[]
  agendamentos   ag_agendamentos[]
  bloqueios      ag_bloqueios[]
}

model ag_usuarios {
  id         String      @id @default(uuid())
  empresa_id String
  nome       String
  email      String      @unique
  senha_hash String
  perfil     String      @default("funcionario")
  ativo      Boolean     @default(true)
  deleted_at DateTime?
  criado_em  DateTime    @default(now())
  empresa    ag_empresas @relation(fields: [empresa_id], references: [id])
}

model ag_profissionais {
  id           String            @id @default(uuid())
  empresa_id   String
  usuario_id   String?
  nome         String
  cor          String            @default("#C4748A")
  comissao_pct Decimal           @default(0)
  ativo        Boolean           @default(true)
  deleted_at   DateTime?
  criado_em    DateTime          @default(now())
  empresa      ag_empresas       @relation(fields: [empresa_id], references: [id])
  agendamentos ag_agendamentos[]
  bloqueios    ag_bloqueios[]
}

model ag_clientes {
  id           String            @id @default(uuid())
  empresa_id   String
  nome         String
  telefone     String?
  aniversario  DateTime?
  debito       Decimal           @default(0)
  observacoes  String?
  deleted_at   DateTime?
  criado_em    DateTime          @default(now())
  empresa      ag_empresas       @relation(fields: [empresa_id], references: [id])
  agendamentos ag_agendamentos[]
}

model ag_servicos {
  id           String            @id @default(uuid())
  empresa_id   String
  nome         String
  duracao_min  Int               @default(60)
  preco        Decimal           @default(0)
  ativo        Boolean           @default(true)
  deleted_at   DateTime?
  criado_em    DateTime          @default(now())
  empresa      ag_empresas       @relation(fields: [empresa_id], references: [id])
  agendamentos ag_agendamentos[]
}

model ag_agendamentos {
  id               String           @id @default(uuid())
  empresa_id       String
  cliente_id       String
  profissional_id  String
  servico_id       String
  data_hora_inicio DateTime
  duracao_min      Int
  data_hora_fim    DateTime
  valor            Decimal
  comissao_pct     Decimal          @default(0)
  comissao_valor   Decimal          @default(0)
  status           String           @default("agendado")
  forma_pagamento  String?
  observacoes      String?
  version          Int              @default(1)
  deleted_at       DateTime?
  criado_em        DateTime         @default(now())
  finalizado_em    DateTime?
  empresa          ag_empresas      @relation(fields: [empresa_id], references: [id])
  cliente          ag_clientes      @relation(fields: [cliente_id], references: [id])
  profissional     ag_profissionais @relation(fields: [profissional_id], references: [id])
  servico          ag_servicos      @relation(fields: [servico_id], references: [id])
}

model ag_bloqueios {
  id               String           @id @default(uuid())
  empresa_id       String
  profissional_id  String
  data_hora_inicio DateTime
  data_hora_fim    DateTime
  motivo           String?
  criado_em        DateTime         @default(now())
  empresa          ag_empresas      @relation(fields: [empresa_id], references: [id])
  profissional     ag_profissionais @relation(fields: [profissional_id], references: [id])
}