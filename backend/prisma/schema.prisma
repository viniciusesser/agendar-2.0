generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ag_empresas {
  id             String         @id @default(uuid())
  nome           String
  telefone       String?
  plano          String         @default("free")
  plano_validade DateTime?
  ativo          Boolean        @default(true)
  deleted_at     DateTime?
  criado_em      DateTime       @default(now())
  usuarios       ag_usuarios[]
  profissionais  ag_profissionais[]
}

model ag_usuarios {
  id         String      @id @default(uuid())
  empresa_id String
  nome       String
  email      String      @unique
  senha_hash String
  perfil     String      @default("funcionario")
  ativo      Boolean     @default(true)
  deleted_at DateTime?
  criado_em  DateTime    @default(now())
  empresa    ag_empresas @relation(fields: [empresa_id], references: [id])
}

model ag_profissionais {
  id           String      @id @default(uuid())
  empresa_id   String
  usuario_id   String?
  nome         String
  cor          String      @default("#C4748A")
  comissao_pct Decimal     @default(0)
  ativo        Boolean     @default(true)
  deleted_at   DateTime?
  criado_em    DateTime    @default(now())
  empresa      ag_empresas @relation(fields: [empresa_id], references: [id])
}